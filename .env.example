# Django Settings
SECRET_KEY=replace_this_with_a_long_random_string
DEBUG=True

# Provide your TMDB API Key (v3 auth)
TMDB_API_KEY=your_tmdb_api_key_here

# PostgreSQL Database (Change credentials to match your local installation)
# Format: postgresql://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/movies

# Cloudinary (Optional for now in dev, but since you have it, paste it here)
CLOUDINARY_URL=cloudinary://my_key:my_secret@my_cloud_name

# Redis (OPTIONAL NOW - We will use local memory cache until you install Redis)
REDIS_URL=redis://localhost:6379/1
